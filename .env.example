# ─────────────────────────────────────────────────────────────
# Yuki's Running Map · environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is git-ignored — never commit secrets.

# Supabase project URL (public, exposed to client).
# Example: https://abcdefghij.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) API key (exposed to client).
# Found in Supabase dashboard → Project settings → API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (server-only · grants admin access · NEVER expose).
# Used by Server Actions and migrations.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase direct Postgres connection string (server-only · used by Drizzle migrations).
# Found in Supabase dashboard → Project settings → Database → Connection string → URI.
# Use the "Direct connection" variant (port 5432) — pooler ports are for runtime queries.
# Example: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Supabase Auth JWT signing secret (server-only · used by Playwright E2E mock fixture).
# Found in Supabase dashboard → Project settings → API → JWT Settings → JWT Secret.
# NOT the same as service-role key. Required for task 8.3 e2e tests.
SUPABASE_JWT_SECRET=

# Yuki's GitHub username (used by middleware to gate /admin/*).
# Only this GitHub account can sign in to the admin surface.
# IMPORTANT: must match the exact case GitHub returns in OAuth user_metadata.user_name
# (preserved as user typed at GitHub signup, NOT lowercased). The same value must be
# wired into the public.app_admin_github_username() SQL function (see migration 0001/0002).
ADMIN_GITHUB_USERNAME=

# Public URL to the Protomaps PMTiles file (used by MapLibre).
# Example: https://<project>.supabase.co/storage/v1/object/public/tiles/taiwan.pmtiles
NEXT_PUBLIC_PMTILES_URL=
